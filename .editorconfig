root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = tab
indent_size = 4
tab_width = 4
max_line_length = 120

# PowerShell formatting is owned by PSScriptAnalyzerSettings.psd1
# (indentation, brace style, whitespace, line length, trailing whitespace).
# Properties below are unset so nothing cascades in from [*] above.
[*.ps1]
charset = unset
end_of_line = unset
insert_final_newline = unset
trim_trailing_whitespace = unset
indent_style = unset
indent_size = unset
tab_width = unset
max_line_length = unset

[*.{json,jsonc,yml,yaml}]
indent_style = tab
indent_size = 4
tab_width = 4

[*.md]
max_line_length = off
